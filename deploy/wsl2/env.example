# Copy this file to .env and replace every secret before first use.
POSTGRES_DB=dataset_platform
POSTGRES_USER=dataset
POSTGRES_PASSWORD=CHANGE_THIS_POSTGRES_PASSWORD

MINIO_ROOT_USER=dataset-minio
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD
MINIO_BUCKET=dataset-platform
# Keep presigned URLs same-origin. Nginx streams /storage/ to MinIO without buffering large bodies.
MINIO_PUBLIC_ENDPOINT=/storage
MINIO_API_CORS_ALLOW_ORIGIN=http://127.0.0.1:8080

NGINX_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

APP_ENV=production
APP_BOOTSTRAP_EMAIL=admin@example.local
APP_BOOTSTRAP_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
APP_BOOTSTRAP_ORGANIZATION=Default Workspace
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
TOKEN_SECRET=CHANGE_THIS_WITH_A_LONG_RANDOM_VALUE_AT_LEAST_32_CHARS
MAX_UPLOAD_BYTES=10737418240

# Worker resource/time limits for untrusted archive handling.
WORKER_MEMORY_LIMIT=4g
WORKER_CPU_LIMIT=2.0
WORKER_TASK_SOFT_TIME_LIMIT=3600
WORKER_TASK_TIME_LIMIT=4200
WORKER_CONCURRENCY=2
WORKER_PREFETCH_MULTIPLIER=1
WORKER_MAX_TASKS_PER_CHILD=20
WORKER_TEMP_RESERVE_BYTES=1073741824



# Readiness fails when free temporary-disk space drops below this threshold.
HEALTH_MIN_FREE_BYTES=1073741824

