# Native WSL2 deployment (no Docker)
# Copy to /etc/dataset-platform/dataset-platform.env by install-native.sh.

APP_ROOT=/home/qt/projects/dataset-platform
APP_USER=dataset-platform
DATA_ROOT=/var/lib/dataset-platform
MINIO_DATA_DIR=/var/lib/dataset-platform/minio
MINIO_BINARY=/usr/local/bin/minio
# Optional cached Linux binary path, for example /mnt/c/tmp/minio.linux-amd64.
MINIO_LOCAL_SOURCE=

POSTGRES_DB=dataset_platform
POSTGRES_USER=dataset
POSTGRES_PASSWORD=CHANGE_THIS_POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://dataset:CHANGE_THIS_POSTGRES_PASSWORD@127.0.0.1:5432/dataset_platform
REDIS_URL=redis://127.0.0.1:6379/0

MINIO_ROOT_USER=dataset-minio
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD
MINIO_ACCESS_KEY=dataset-minio
MINIO_SECRET_KEY=CHANGE_THIS_MINIO_PASSWORD
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_BUCKET=dataset-platform
MINIO_SECURE=false
MINIO_API_CORS_ALLOW_ORIGIN=http://127.0.0.1:8080

APP_ENV=production
APP_BOOTSTRAP_EMAIL=admin@example.local
APP_BOOTSTRAP_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
APP_BOOTSTRAP_ORGANIZATION="Default Workspace"
TOKEN_SECRET=CHANGE_THIS_WITH_A_LONG_RANDOM_VALUE_AT_LEAST_32_CHARS
MAX_UPLOAD_BYTES=10737418240
WORKER_TMP_DIR=/var/lib/dataset-platform/worker-tmp
WORKER_MEMORY_LIMIT=4g
WORKER_CPU_LIMIT=2.0
WORKER_TASK_SOFT_TIME_LIMIT=3600
WORKER_TASK_TIME_LIMIT=4200
WORKER_CONCURRENCY=2
WORKER_PREFETCH_MULTIPLIER=1
WORKER_MAX_TASKS_PER_CHILD=20
WORKER_TEMP_RESERVE_BYTES=1073741824
HEALTH_MIN_FREE_BYTES=1073741824

NGINX_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001


